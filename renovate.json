{
    "extends": [
        "config:recommended",
        "group:allNonMajor",
        "schedule:weekends",
        ":automergePatch"
    ],
    "rangeStrategy": "update-lockfile",
    "postUpdateOptions": ["npmDedupe"],
    "lockFileMaintenance": {
        "enabled": true
    },
    "internalChecksFilter": "strict",
    "minimumReleaseAge": "5 days",
    "packageRules": [
        {
            "matchUpdateTypes": ["lockFileMaintenance"],
            "minimumReleaseAge": null
        }
    ]
}